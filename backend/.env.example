# Copy this file to .env and adjust. Loaded automatically via
# `node --env-file-if-exists=.env` (see the start/dev scripts).

# Ports
SYNCSTART_UDP_PORT=53000
WEBSOCKET_PORT=8080

# Google Sheets logging. SPREADSHEET_ID is REQUIRED — the server refuses to
# start without it (and verifies the service account can access the sheet).
SPREADSHEET_ID=1fa88lJihFOGGjR3yZiPHo70LOPRWlRLrFFn_I1yFJg4
SCORES_TAB_NAME=Scores

# Path to the Google service-account credentials (relative to the backend dir,
# or absolute). This file stays local and is gitignored — never commit it.
GOOGLE_KEY_FILE=keys.json

# Scoring: max difference in currentPossibleDancePoints before ranking falls
# back to percentage-based sorting.
MAX_POSSIBLE_DANCE_POINTS_DIFFERENCE=100
